#!/bin/bash

CONFIG="/etc/batterymqtt/config.conf"

# Load configuration
if [ ! -f "$CONFIG" ]; then
    echo "Configuration file not found: $CONFIG"
    exit 1
fi

source "$CONFIG"

echo "BatteryMQTT started"
echo "Device: $DEVICE_NAME"

while true
do

    # Detect battery
    BATTERY=$(ls /sys/class/power_supply/ | grep '^BAT' | head -n 1)

    if [ -z "$BATTERY" ]; then
        echo "No battery detected. Waiting 60 seconds..."
        sleep 60
        continue
    fi

    echo "Battery detected: $BATTERY"

    CAPACITY=$(cat /sys/class/power_supply/$BATTERY/capacity)
    STATUS=$(cat /sys/class/power_supply/$BATTERY/status)

    echo "Battery: $CAPACITY%"
    echo "Status: $STATUS"

    # Publish battery percentage
    mosquitto_pub \
    -h "$MQTT_HOST" \
    -p "$MQTT_PORT" \
    -u "$MQTT_USER" \
    -P "$MQTT_PASS" \
    -t "BatteryMQTT/$DEVICE_NAME/battery" \
    -m "$CAPACITY"

    # Publish battery status
    mosquitto_pub \
    -h "$MQTT_HOST" \
    -p "$MQTT_PORT" \
    -u "$MQTT_USER" \
    -P "$MQTT_PASS" \
    -t "BatteryMQTT/$DEVICE_NAME/status" \
    -m "$STATUS"

    sleep 60

done
